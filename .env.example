# ============================================
# YukTaxi — Environment Variables
# ============================================

# === DATABASE (required for deployment) ===
# Local dev (SQLite file):
# DATABASE_URL="file:./db/custom.db"

# Vercel/Turso deployment:
DATABASE_URL="libsql://yuktaxi-YOURNAME.turso.io"
DATABASE_AUTH_TOKEN="your-turso-auth-token"

# === YANDEX MAPS (optional) ===
# Leave empty — Yandex Maps works without a key for basic usage.
# For higher rate limits, get a free key at https://yandex.ru/dev/maps/
# NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""

# === SMS / OTP (optional) ===
# If NOT set, OTP is printed to server logs (demo mode — great for testing).
# For real SMS via Eskiz.uz:
# ESKIZ_EMAIL="your@email.com"
# ESKIZ_PASSWORD="your-password"

# === AI CARGO ANALYSIS (optional) ===
# Used for photo comparison & cargo analysis features.
# If NOT set, these features fall back to heuristic mode.
# GEMINI_API_KEY="your-gemini-key"